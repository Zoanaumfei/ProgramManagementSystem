{
  "family": "program-management-system",
  "taskRoleArn": "arn:aws:iam::439533253319:role/program-management-system-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::439533253319:role/program-management-system-ecs-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "program-management-system",
      "image": "439533253319.dkr.ecr.sa-east-1.amazonaws.com/oryzem-backend-dev:custom-login-20260323-0053",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "http-8080"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "sa-east-1"
        },
        {
          "name": "DB_SECRET_ID",
          "value": "program-management-system/rds/master"
        },
        {
          "name": "APP_BOOTSTRAP_INTERNAL_ADMIN_ENABLED",
          "value": "false"
        },
        {
          "name": "APP_SECURITY_IDENTITY_USER_POOL_ID",
          "value": "sa-east-1_aA4I3tEmF"
        },
        {
          "name": "APP_SECURITY_IDENTITY_REGION",
          "value": "sa-east-1"
        },
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "rds"
        },
        {
          "name": "APP_SECURITY_IDENTITY_PROVIDER",
          "value": "cognito"
        },
        {
          "name": "APP_BOOTSTRAP_INTERNAL_ADMIN_PRUNE_OTHER_INTERNAL_USERS",
          "value": "false"
        },
        {
          "name": "DB_SSL_MODE",
          "value": "require"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/program-management-system",
          "awslogs-region": "sa-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -fsS http://localhost:8080/actuator/health/liveness || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 90
      }
    }
  ]
}
