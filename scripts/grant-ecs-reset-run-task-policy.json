{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRunProgramManagementSystemResetTask",
      "Effect": "Allow",
      "Action": [
        "ecs:RunTask"
      ],
      "Resource": "arn:aws:ecs:sa-east-1:439533253319:task-definition/program-management-system:*"
    },
    {
      "Sid": "AllowInspectProgramManagementSystemResetTask",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices",
        "ecs:DescribeTasks"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowPassProgramManagementSystemTaskRoles",
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": [
        "arn:aws:iam::439533253319:role/program-management-system-ecs-task-role",
        "arn:aws:iam::439533253319:role/program-management-system-ecs-execution-role"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    }
  ]
}
